---
import { formatDate, readingTime } from '~/lib/utils';
import TOC from '~/components/TOC.astro';
import Comments from '~/components/Comments.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  categories: string[];
  tags: string[];
  cover?: string;
  content: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  categories,
  tags,
  cover,
  content,
  headings,
} = Astro.props;
---

<BaseLayout title={`${title} | My Blog`} description={description} image={cover} type="article">
  <main class="flex-1 w-full max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- 主内容区 -->
      <div class="flex-1 min-w-0">
        <!-- 文章头部 -->
        <header class="glass p-8 mb-8">
          <div class="flex flex-wrap gap-2 mb-4">
            {categories.map((cat) => (
              <a
                href={`/category/${cat}`}
                class="text-xs px-3 py-1 rounded-full"
                style="background: var(--accent-primary); color: #fff;"
              >
                {cat}
              </a>
            ))}
          </div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: 'Noto Serif SC', serif;">
            {title}
          </h1>
          <p class="text-sm" style="color: var(--text-tertiary);">
            {formatDate(pubDate)}
            {updatedDate && ` · 更新于 ${formatDate(updatedDate)}`}
            · {readingTime(content)}
          </p>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <a
                  href={`/tag/${tag}`}
                  class="text-xs px-2 py-0.5 rounded glass-sm hover:opacity-80 transition-opacity"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        <!-- 文章内容 -->
        <article class="glass p-8 mb-8" data-pagefind-body>
          <div class="prose">
            <slot />
          </div>
        </article>

        <!-- 评论 -->
        <Comments />

        <!-- 返回列表 -->
        <div class="text-center mt-8">
          <a href="/blog" class="glass-sm inline-block px-6 py-3 glass-hover">
            ← 返回文章列表
          </a>
        </div>
      </div>

      <!-- 侧边栏目录 -->
      <aside class="hidden lg:block w-64 shrink-0">
        <TOC headings={headings} />
      </aside>
    </div>
  </main>
</BaseLayout>
