---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="neo-card p-12 text-center max-w-lg">
      <h1 class="text-6xl font-black mb-4" style="color: var(--accent-blue);">404</h1>
      <p class="text-xl font-bold mb-2" style="font-family: 'Noto Serif SC', serif;">页面走丢了</p>
      <p class="mb-8" style="color: var(--text-secondary);">
        你访问的页面不存在或已被移除
      </p>
      <a href="/" class="neo-btn neo-btn-primary inline-block px-8 py-3">
        返回首页
      </a>
    </div>
  </main>
</BaseLayout>
