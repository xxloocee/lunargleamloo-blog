---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="glass p-12 text-center max-w-lg">
      <h1 class="text-6xl font-bold mb-4" style="color: var(--accent-primary);">404</h1>
      <p class="text-xl mb-2" style="font-family: 'Noto Serif SC', serif;">页面走丢了</p>
      <p class="mb-8" style="color: var(--text-secondary);">
        你访问的页面不存在或已被移除
      </p>
      <a href="/" class="glass-sm inline-block px-8 py-3 glass-hover">
        返回首页
      </a>
    </div>
  </main>
</BaseLayout>
