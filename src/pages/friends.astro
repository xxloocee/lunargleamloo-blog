---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE_CONFIG } from '~/lib/constants';

const friends = [
  {
    author: 'shiqkuangsan',
    org: 'antdv-next',
    title: '当 AI 能写完整个项目，我们还需要组件库吗？',
    url: 'https://mp.weixin.qq.com/s/-WDJzlHyMKFs22Ao0OjC3w',
    platform: '微信公众号 · Antdv Next',
    pubDate: '2026-03-27',
    tags: ['AI', '组件库', '前端'],
    summary: '从 Ant Design Vue 维护者的视角出发，探讨 AI 原生时代组件库的生存价值——代码生成只是冰山一角，API 契约、设计系统和品牌一致性才是不可替代的核心。',
  },
];
---

<BaseLayout title={`友链 | ${SITE_CONFIG.title}`} description="来自朋友们的优质文章推荐">
  <main class="flex-1 w-full max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2" style="font-family: 'Noto Serif SC', serif;">友链</h1>
      <p class="text-sm" style="color: var(--text-tertiary);">
        来自朋友们的优质文章推荐，每一篇都值得细读。
      </p>
    </div>
    <div class="space-y-4">
      {friends.map((friend) => (
        <a href={friend.url} target="_blank" rel="noopener noreferrer" class="neo-card neo-hover p-6 block" style="color: var(--text-primary);">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-xs" style="color: var(--text-tertiary);">
              {friend.pubDate}
            </span>
            <span class="neo-badge">{friend.platform}</span>
            <span class="text-xs" style="color: var(--text-secondary);">
              @{friend.author}
            </span>
          </div>
          <h2 class="text-xl font-bold mb-2">{friend.title}</h2>
          <p class="text-sm" style="color: var(--text-secondary);">
            {friend.summary}
          </p>
          {friend.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
              {friend.tags.map((tag) => (
                <span class="neo-tag">#{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
