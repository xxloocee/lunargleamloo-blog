---

---

<!-- 搜索弹窗 -->
<div
  id="search-modal"
  class="fixed inset-0 z-100 hidden items-start justify-center pt-[15vh]"
  style="background: rgba(0,0,0,0.5);"
>
  <div class="neo-card-lg w-full max-w-2xl mx-4 p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xl">🔍</span>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章..."
        class="flex-1 bg-transparent border-none outline-none text-lg"
        style="color: var(--text-primary);"
        autocomplete="off"
      />
      <button
        id="search-close"
        class="text-sm px-2 py-1 rounded font-bold hover:opacity-80"
        style="background: var(--neo-surface-alt); border: 1.5px solid var(--neo-border-color);"
      >
        ESC
      </button>
    </div>
    <div id="search-results" class="max-h-[50vh] overflow-y-auto space-y-2">
      <p class="text-sm text-center py-4" style="color: var(--text-tertiary);">
        输入关键字开始搜索...
      </p>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var modal = document.getElementById("search-modal");
    var input = document.getElementById("search-input");
    var results = document.getElementById("search-results");
    var closeBtn = document.getElementById("search-close");
    var triggers = document.querySelectorAll(".search-trigger-btn");

    if (!modal || !input || !results || !closeBtn || triggers.length === 0) return;

    var searchIndex = null;
    var postsData = [];

    function openSearch() {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      input.focus();
    }

    function closeSearch() {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      input.value = "";
      results.innerHTML =
        '<p class="text-sm text-center py-4" style="color: var(--text-tertiary);">输入关键字开始搜索...</p>';
    }

    async function loadSearchIndex() {
      if (searchIndex) return searchIndex;
      try {
        var response = await fetch("/pagefind/pagefind.js");
        if (response.ok) {
          var pagefind = await import("/pagefind/pagefind.js");
          searchIndex = await pagefind.init();
          return searchIndex;
        }
      } catch {}
      return null;
    }

    async function loadPosts() {
      if (postsData.length) return;
      try {
        var res = await fetch("/search-index.json");
        if (res.ok) postsData = await res.json();
      } catch {}
    }

    triggers.forEach(function(trigger) {
      trigger.addEventListener("click", openSearch);
    });

    closeBtn.addEventListener("click", closeSearch);
    modal.addEventListener("click", function (e) {
      if (e.target === modal) closeSearch();
    });

    document.addEventListener("keydown", function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openSearch();
      }
      if (e.key === "Escape") closeSearch();
    });

    input.addEventListener("input", async function (e) {
      var query = e.target.value.trim().toLowerCase();
      if (!query) {
        results.innerHTML =
          '<p class="text-sm text-center py-4" style="color: var(--text-tertiary);">输入关键字开始搜索...</p>';
        return;
      }

      var pf = await loadSearchIndex();
      if (pf) {
        var searchResults = await pf.search(query);
        if (searchResults.results.length) {
          results.innerHTML = searchResults.results
            .slice(0, 8)
            .map(function (r) {
              return (
                '<a href="' + r.url + '" class="block p-3 rounded hover:opacity-80" style="background: var(--neo-surface-alt); border: 1.5px solid var(--neo-border-color); border-radius: 8px;">' +
                '<div class="font-medium">' + (r.meta && r.meta.title || "无标题") + "</div>" +
                '<div class="text-xs mt-1" style="color: var(--text-tertiary);">' + (r.excerpt || "") + "</div>" +
                "</a>"
              );
            })
            .join("");
        } else {
          results.innerHTML =
            '<p class="text-sm text-center py-4" style="color: var(--text-tertiary);">未找到相关结果</p>';
        }
        return;
      }

      await loadPosts();
      var matched = postsData.filter(function (p) {
        return (
          p.title.toLowerCase().includes(query) ||
          p.description.toLowerCase().includes(query) ||
          p.tags.some(function (t) { return t.toLowerCase().includes(query); })
        );
      });

      if (matched.length) {
        results.innerHTML = matched
          .slice(0, 8)
          .map(function (p) {
            return (
              '<a href="' + p.url + '" class="block p-3 rounded hover:opacity-80" style="background: var(--neo-surface-alt); border: 1.5px solid var(--neo-border-color); border-radius: 8px;">' +
              '<div class="font-medium">' + p.title + "</div>" +
              '<div class="text-xs mt-1" style="color: var(--text-tertiary);">' + p.description + "</div>" +
              "</a>"
            );
          })
          .join("");
      } else {
        results.innerHTML =
          '<p class="text-sm text-center py-4" style="color: var(--text-tertiary);">未找到相关结果</p>';
      }
    });
  })();
</script>
