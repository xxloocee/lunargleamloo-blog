---
import { SITE_CONFIG } from "~/lib/constants";
import SearchTrigger from "~/components/SearchTrigger.astro";
import SearchModal from "~/components/SearchModal.astro";

const navLinks = [
  { href: "/", label: "首页" },
  { href: "/blog", label: "文章" },
  { href: "/archive", label: "归档" },
  { href: "/category", label: "分类" },
  { href: "/friends", label: "友链" },
  { href: "/shiyi", label: "拾遗" },
  { href: "/about", label: "关于" },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  if (href === "/blog") return pathname.startsWith("/blog");
  if (href === "/category") return pathname.startsWith("/category");
  if (href === "/shiyi") return pathname.startsWith("/shiyi");
  return pathname === href;
}
---

<header
  class="shrink-0 z-50 px-4 py-3"
  style="background: var(--neo-surface); border-bottom: var(--neo-border); box-shadow: 0 4px 0px var(--neo-border-color);"
>
  <nav class="max-w-6xl mx-auto flex items-center justify-between">
    <a
      href="/"
      class="text-lg font-extrabold"
      style="font-family: 'Noto Serif SC', serif; color: var(--accent-orange);"
    >
      {SITE_CONFIG.title}
    </a>

    <!-- 桌面端导航 -->
    <div class="hidden md:flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`nav-link neo-chip text-sm font-semibold px-3 py-1.5 ${isActive(link.href) ? "is-active" : ""}`}
            aria-current={isActive(link.href) ? "page" : undefined}
            style="color: var(--text-primary);"
          >
            {link.label}
          </a>
        ))
      }
      <SearchTrigger />
      <button
        id="dark-mode-toggle"
        class="neo-chip ml-2 w-9 h-9 font-bold text-sm"
        style="background: var(--neo-surface-alt);"
        aria-label="切换深色模式"
      >
        🌓
      </button>
    </div>

    <!-- 移动端菜单按钮 -->
    <div class="flex md:hidden items-center gap-2">
      <SearchTrigger />
      <button
        id="dark-mode-toggle-mobile"
        class="neo-chip w-9 h-9 text-sm"
        style="background: var(--neo-surface-alt);"
        aria-label="切换深色模式"
      >
        🌓
      </button>
      <button
        id="mobile-menu-toggle"
        class="neo-chip w-9 h-9 text-xl font-bold"
        style="background: var(--neo-surface-alt);"
        aria-label="打开菜单"
      >
        ☰
      </button>
    </div>
  </nav>

  <!-- 移动端菜单 -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-3 pb-2 pt-3"
    style="border-top: var(--neo-border);"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={`block py-2 px-3 text-sm font-semibold rounded-lg transition-colors ${isActive(link.href) ? "mobile-link-active" : ""}`}
          aria-current={isActive(link.href) ? "page" : undefined}
          style="color: var(--text-primary);"
        >
          {link.label}
        </a>
      ))
    }
  </div>
  <SearchModal />
</header>

<style>
  .nav-link:hover {
    background: var(--accent-orange);
    color: var(--text-primary);
  }

  .nav-link.is-active {
    background: var(--accent-orange);
    box-shadow: var(--neo-shadow);
  }

  .mobile-link-active {
    background: var(--neo-surface-alt);
    border: var(--neo-border);
    box-shadow: var(--neo-shadow-sm);
  }
</style>

<script is:inline>
  (function () {
    function toggleTheme() {
      var html = document.documentElement;
      var current = html.getAttribute("data-theme");
      var next = current === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
    }

    var toggleBtn = document.getElementById("dark-mode-toggle");
    var toggleBtnMobile = document.getElementById("dark-mode-toggle-mobile");
    if (toggleBtn) toggleBtn.addEventListener("click", toggleTheme);
    if (toggleBtnMobile) toggleBtnMobile.addEventListener("click", toggleTheme);

    var menuToggle = document.getElementById("mobile-menu-toggle");
    if (menuToggle) {
      menuToggle.addEventListener("click", function () {
        var menu = document.getElementById("mobile-menu");
        if (menu) menu.classList.toggle("hidden");
      });
    }
  })();
</script>
