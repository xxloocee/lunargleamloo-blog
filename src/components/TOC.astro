---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="glass-sm p-4 sticky top-20" aria-label="文章目录">
    <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">目录</h3>
    <ul class="space-y-1.5 text-sm">
      {filteredHeadings.map((heading) => (
        <li style={`padding-left: ${(heading.depth - 1) * 12}px;`}>
          <a
            href={`#${heading.slug}`}
            class="block py-0.5 hover:opacity-80 transition-opacity"
            style="color: var(--text-secondary);"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
