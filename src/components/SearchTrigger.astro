---
/* 搜索触发按钮组件
 * 
 * 2026-03-25: 创建独立触发器，解决 ID 冲突导致的移动端失效问题。
 */
---

<button
  class="search-trigger-btn neo-chip px-3 py-1.5 text-sm flex items-center gap-2 font-semibold"
  aria-label="搜索文章"
  style="color: var(--text-primary);"
>
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m20 20-3.5-3.5"></path>
  </svg>
  <span class="hidden sm:inline">搜索...</span>
  <kbd
    class="hidden sm:inline text-xs px-1.5 py-0.5 rounded"
    style="background: var(--neo-surface-alt); color: var(--text-tertiary); border: 1.5px solid var(--neo-border-color);"
    >⌘K</kbd
  >
</button>
