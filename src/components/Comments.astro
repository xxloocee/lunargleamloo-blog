---
import { SITE_CONFIG } from '~/lib/constants';

interface Props {
  term?: string;
}

const { term = '' } = Astro.props;
---

<section class="mt-12">
  <h2 class="text-xl font-bold mb-4" style="font-family: 'Noto Serif SC', serif;">评论</h2>
  <div class="glass p-6">
    <script
      src="https://giscus.app/client.js"
      data-repo="loocee/my-blog"
      data-repo-id="R_kgDOH-s37Q"
      data-category="General"
      data-category-id="DIC_kwDOH-s37c4C_99e"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="dark_dimmed"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>
